.container {
  padding: 20px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
}

.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24px;
}

.scan-tip {
  font-size: 16px;
}

.scan-icon {
  font-size: 64px;
}
