.container {
  padding: 20px;
  min-height: 100vh;
}

.section {
  margin-bottom: 32px;
}

.section-title {
  font-size: 14px;
  margin-bottom: 12px;
  padding: 0 4px;
}

.today-card {
  padding: 24px;
  text-align: center;
}

.today-count {
  font-size: 48px;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 8px;
}

.today-detail {
  font-size: 14px;
}

.brand-breakdown {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8px;
  margin-top: 16px;
}

.brand-tag {
  background-color: #2c2c2e;
  padding: 2px 6px;
  border-radius: 10px;
  font-size: 10px;
  display: inline-block;
  text-align: center;
}

.week-card {
  padding: 24px;
}

.week-chart {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  height: 120px;
  margin-bottom: 16px;
}

.chart-bar {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-fill {
  width: 24px;
  background-color: #0a84ff;
  border-radius: 4px 4px 0 0;
  min-height: 4px;
  transition: height 0.3s;
}

.bar-label {
  font-size: 12px;
  margin-top: 8px;
}

.bar-count {
  font-size: 12px;
  margin-top: 4px;
}

.week-brands {
  display: flex;
  justify-content: space-between;
  margin-top: 12px;
}

.week-brand-item {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: center;
  align-items: flex-start;
  gap: 4px;
  flex: 1;
  padding: 0 2px;
}

.week-avg {
  text-align: center;
  font-size: 14px;
}

.history-item {
  padding: 16px;
  margin-bottom: 12px;
}

.history-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.history-date {
  font-size: 16px;
}

.history-count {
  font-size: 16px;
}

.history-brands {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
}

.brand-text {
  font-size: 12px;
}

.empty-tip {
  text-align: center;
  padding: 40px;
  font-size: 14px;
}